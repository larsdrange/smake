# Supabase — find these in your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Places API — https://console.cloud.google.com
# Enable: Places API, Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin user emails (comma-separated) — these get super-admin role on first login
ADMIN_EMAILS=your@email.com,other-admin@email.com
